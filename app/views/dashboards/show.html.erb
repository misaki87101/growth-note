<div style="max-width: 700px; margin: 60px auto; padding: 0 20px; font-family: 'Helvetica Neue', Arial, sans-serif; color: #1a1a1a;">
  
  <%# タイトル %>
  <div style="text-align: center; margin-bottom: 60px;">
    <h1 style="font-size: 22px; font-weight: 300; letter-spacing: 0.15em; margin-bottom: 10px; text-transform: uppercase;">My Growth Note</h1>
    <div style="font-size: 10px; color: #999; letter-spacing: 0.2em;">LEARNING ARCHIVE</div>
  </div>

  <%# ナビゲーションメニュー %>
  <div style="display: flex; justify-content: center; gap: 40px; margin-bottom: 60px; border-bottom: 1px solid #eee;">
    <%# FEEDBACKタブ %>
    <div style="padding-bottom: 15px; border-bottom: 2px solid #1a1a1a;">
      <%= link_to "FEEDBACK", mypage_path, style: "text-decoration: none; color: #1a1a1a; font-size: 11px; letter-spacing: 0.15em; font-weight: bold;" %>
    </div>
    <%# HOMEWORKタブ %>
    <div style="padding-bottom: 15px;">
      <%= link_to "HOMEWORK", homeworks_path, style: "text-decoration: none; color: #999; font-size: 11px; letter-spacing: 0.15em;" %>
    </div>
    <%# BOARDタブ %>
    <div style="padding-bottom: 15px;">
      <%= link_to "BOARD", boards_path, style: "text-decoration: none; color: #999; font-size: 11px; letter-spacing: 0.15em;" %>
    </div>
  </div>

  <%# 生徒絞り込み %>
<% if current_user.teacher? %>
  <div style="margin-bottom: 40px; border-bottom: 1px solid #f0f0f0; padding-bottom: 30px;">
    <%= form_with url: mypage_path, method: :get, local: true do |f| %>
      <div style="display: flex; gap: 10px; align-items: center;">
        <span style="font-size: 10px; letter-spacing: 0.1em; color: #999;">FILTER STUDENT:</span>
        <%= f.collection_select :student_id, @students || [], :id, :name, 
            { include_blank: "ALL STUDENTS", selected: params[:student_id] }, 
            { style: "border: none; border-bottom: 1px solid #e5e5e5; padding: 5px; font-size: 12px; color: #1a1a1a; background: transparent; outline: none;" } %>
        <%= f.submit "SEARCH", style: "background: #1a1a1a; border: none; font-size: 9px; letter-spacing: 0.1em; cursor: pointer; color: #fff; padding: 5px 15px;" %>
        <% if params[:student_id].present? %>
          <%= link_to "CLEAR", mypage_path, style: "font-size: 10px; color: #ccc; text-decoration: none; margin-left: 10px;" %>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

  <%# コンテンツエリア（既存のフィードバック一覧） %>
  <div style="margin-bottom: 40px; display: flex; justify-content: space-between; align-items: baseline;">
    <h2 style="font-size: 12px; font-weight: 600; letter-spacing: 0.1em; color: #1a1a1a; margin: 0;">LESSON FEEDBACKS</h2>
    <span style="font-size: 10px; color: #999;"><%= @feedbacks.count %> Records</span>
  </div>

  <% if @feedbacks.any? %>
    <div style="display: flex; flex-direction: column;">
      <% @feedbacks.each do |feedback| %>
        <%= link_to feedback_path(feedback), style: "text-decoration: none; color: inherit; display: block; border-bottom: 1px solid #eee; padding: 40px 0; transition: opacity 0.3s;" do %>
          <div style="display: flex; gap: 40px; align-items: flex-start;">

            <%# スコア & アイコン（左側に配置） %>
            <div style="width: 45px; text-align: center; flex-shrink: 0;">
              <div style="font-size: 20px; font-family: 'Georgia', serif; font-weight: 300; border-bottom: 1px solid #1a1a1a; display: inline-block; min-width: 25px;">
                <%= feedback.rating %>
              </div>
              <div style="font-size: 8px; color: #999; margin-top: 5px; margin-bottom: 10px;">SCORE</div>
              
              <%# アイコン類を縦に並べるコンテナ %>
              <div style="display: flex; flex-direction: column; align-items: center; gap: 5px;">
                <% if feedback.new_arrival? %>
                  <span style="font-size: 8px; color: #fff; background: #1a1a1a; padding: 1px 4px; letter-spacing: 0.05em; display: inline-block;">NEW!</span>
                <% end %>

                <% if feedback.images.attached? %>
                  <span style="font-size: 12px; color: #bbb;" title="画像あり">📷</span>
                <% end %>
              </div>
            </div>

            <%# テキストコンテンツ（中央） %>
            <div style="flex-grow: 1;">
              <div style="font-size: 10px; color: #999; letter-spacing: 0.1em; margin-bottom: 5px;">
                <%= feedback.lesson_date.strftime("%Y . %m . %d") %>
              </div>
              <div style="font-size: 16px; font-weight: 500; letter-spacing: 0.05em; margin-bottom: 10px;">
                <%= feedback.title.present? ? feedback.title : "Lesson Feedback" %>
              </div>
              <div style="color: #666; font-size: 13px; line-height: 1.8; letter-spacing: 0.02em;">
                <%= feedback.content.truncate(60) %>
              </div>
            </div>

            <%# 矢印（右側） %>
            <div style="color: #ccc; font-size: 18px; align-self: center;">→</div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div style="text-align: center; padding: 80px 0; color: #999; font-weight: 300; letter-spacing: 0.1em;">
      No records found.
    </div>
  <% end %>
</div>

<style>
  @media print {
    /* 印刷時にボタンやリンクを隠す */
    button, a, .no-print {
      display: none !important;
    }
    
    /* 印刷時の余白調整 */
    body {
      background: white !important;
    }
    div[style*="margin: 60px auto"] {
      margin: 0 !important;
      border: none !important;
      box-shadow: none !important;
      width: 100% !important;
      max-width: 100% !important;
    }
  }
</style>
