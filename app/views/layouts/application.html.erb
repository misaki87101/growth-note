<!DOCTYPE html>
<html>
  <head>
    <title>GrowthNote</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>

    <style>
  body {
    background-color: #fcfcfc;
    margin: 0;
    padding: 0;
    font-family: 'Helvetica Neue', Arial, sans-serif;
    color: #1a1a1a;
  }

  /* ナビバー全体のゆとり */
  .main-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 25px 40px; /* 上下のパディングを少し増やしてゆとりを */
    background-color: #ffffff;
    border-bottom: 1px solid #eee;
    flex-wrap: wrap; /* 要素が入り切らない時に折り返す設定 */
    gap: 20px;
  }

  /* スマホ向けのメディアクエリ */
  @media (max-width: 768px) {
    .main-nav {
      padding: 15px 20px;
      justify-content: center; /* 中央寄せで整列 */
      text-align: center;
    }
    .nav-left, .nav-right {
      width: 100%; /* スマホでは横幅いっぱいに広げて上下2段にする */
      justify-content: center !important;
      margin: 0 !important;
      padding: 0 !important;
      border: none !important;
    }
    .nav-right {
      gap: 15px !important; /* スマホでのボタン同士の距離を確保 */
    }
  }

  @media print {
    nav, .flash-message { display: none !important; }
  }
</style>
  </head>

  <body>
    <%# --- ヘッダー（ナビバー） --- %>
    <nav class="main-nav">
  <%# --- 左側：ロゴとクラス選択 --- %>
  <div class="nav-left" style="display: flex; align-items: center; gap: 25px;">
    <div style="font-size: 16px; letter-spacing: 0.25em; color: #1a1a1a; font-weight: 300;">
      <%= link_to "GROWTH NOTE", root_path, style: "text-decoration: none; color: inherit;" %>
    </div>

    <% if logged_in? %>
      <div style="border-left: 1px solid #eee; padding-left: 20px; display: flex; align-items: center;">
        <% if current_user.teacher? %>
          <%= form_with url: users_path, method: :get, local: true, style: "display: flex; align-items: center; gap: 8px;" do |f| %>
            <span style="font-size: 9px; color: #ccc; letter-spacing: 0.1em;">CLASS:</span>
            <%= f.select :group_id, 
                options_from_collection_for_select(Group.all, :id, :name, params[:group_id]), 
                { include_blank: "ALL" }, 
                { onchange: "this.form.submit();", 
                  style: "background: none; border: none; border-bottom: 1px solid #eee; font-size: 11px; color: #1a1a1a; cursor: pointer; outline: none; padding: 2px;" } 
            %>
            <% if params[:group_id].present? %>
              <%= link_to "EDIT", edit_group_path(params[:group_id]), style: "text-decoration: none; font-size: 9px; color: #999; border: 1px solid #eee; padding: 2px 6px; border-radius: 2px;" %>
            <% end %>
          <% end %>
        <% elsif current_user.group.present? %>
          <span style="font-size: 9px; color: #ccc; letter-spacing: 0.1em; margin-right: 8px;">CLASS:</span>
          <span style="font-size: 11px; color: #1a1a1a;"><%= current_user.group.name %></span>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# --- 右側：各種アクション --- %>
  <div class="nav-right" style="display: flex; align-items: center; gap: 25px;">
    <% if logged_in? %>
      <div style="display: flex; align-items: center; gap: 20px;">
        <% if current_user.teacher? %>
          <%= link_to "+ CLASS", new_group_path, style: "font-size: 10px; color: #1a1a1a; text-decoration: none; letter-spacing: 0.1em;" %>
          <%= link_to "STUDENTS", users_path, style: "font-size: 10px; color: #1a1a1a; text-decoration: none; letter-spacing: 0.1em;" %>
        <% else %>
          <%= link_to "MY PAGE", mypage_path, style: "text-decoration: none; color: #1a1a1a; font-size: 10px; letter-spacing: 0.1em;" %>
        <% end %>
      </div>

      <div style="display: flex; align-items: center; gap: 15px; border-left: 1px solid #eee; padding-left: 20px;">
        <%= link_to user_path(current_user), style: "text-decoration: none; font-size: 10px; color: #1a1a1a; letter-spacing: 0.1em;" do %>
          👤 <%= current_user.name.truncate(10).upcase %>
        <% end %>

        <%= button_to "LOGOUT", logout_path, method: :delete, form: { data: { turbo: false } }, 
            style: "background: none; border: 1px solid #eee; color: #999; font-size: 9px; padding: 5px 10px; cursor: pointer;" %>
      </div>
    <% else %>
      <%= link_to "LOGIN", login_path, style: "text-decoration: none; color: #1a1a1a; font-size: 11px; letter-spacing: 0.2em;" %>
    <% end %>
  </div>
</nav>

    <%# --- Flashメッセージ --- %>
    <div class="flash-message" style="max-width: 600px; margin: 20px auto; text-align: center;">
      <% flash.each do |message_type, message| %>
        <div style="font-size: 12px; color: #666; padding: 10px; border: 1px solid #eee; background: #fff; letter-spacing: 0.05em;">
          <%= message %>
        </div>
      <% end %>
    </div>

    <%= yield %>
  </body>

  <footer style="margin-top: 100px; padding: 60px 0 40px; background-color: #ffffff; border-top: 1px solid #eee; text-align: center;">
    <div style="display: flex; justify-content: center; gap: 30px; margin-bottom: 25px;">
      <%= link_to '利用規約', terms_path, style: "text-decoration: none; color: #999; font-size: 10px; letter-spacing: 0.1em;" %>
      <%= link_to 'プライバシーポリシー', privacy_path, style: "text-decoration: none; color: #999; font-size: 10px; letter-spacing: 0.1em;" %>
    </div>
    
    <div style="font-size: 9px; color: #ccc; letter-spacing: 0.2em;">
      © <%= Time.current.year %> GROWTH NOTE
    </div>
  </footer>
  
</html>
