<!DOCTYPE html>
<html>
  <head>
    <title>GrowthNote</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>

    <style>
      body {
        background-color: #fcfcfc;
        margin: 0;
        padding: 0;
        font-family: 'Helvetica Neue', Arial, sans-serif;
        color: #1a1a1a;
      }
      
      /* 印刷時にヘッダーとフラッシュメッセージを隠す */
      @media print {
        nav, .flash-message {
          display: none !important;
        }
      }
    </style>
  </head>

  <body>
    <%# --- ヘッダー（ナビバー） --- %>
    <nav style="display: flex; justify-content: space-between; align-items: center; padding: 20px 40px; background-color: #ffffff; border-bottom: 1px solid #eee; letter-spacing: 0.1em;">
      
      <%# ロゴ部分 %>
      <div style="font-size: 14px; letter-spacing: 0.2em; color: #1a1a1a; font-weight: 300;">
        <%= link_to "GROWTH NOTE", root_path, style: "text-decoration: none; color: inherit;" %>
      </div>

<%# --- ナビバーの中（ロゴの直後あたり）に追加 --- %>
<div style="display: flex; align-items: center; gap: 15px; margin-left: 20px; border-left: 1px solid #eee; padding-left: 20px;">
  <% if logged_in? %>
    <% if current_user.teacher? %>
      <%# 先生：クラス切り替え用の簡易フォーム %>
      <%= form_with url: users_path, method: :get, local: true, style: "display: flex; align-items: center; gap: 8px;" do |f| %>
        <span style="font-size: 9px; color: #ccc; letter-spacing: 0.1em;">CURRENT CLASS :</span>
        <%= f.select :group_id, 
            options_from_collection_for_select(Group.all, :id, :name, params[:group_id]), 
            { include_blank: "ALL STUDENTS" }, 
            { onchange: "this.form.submit();", 
              style: "background: none; border: none; border-bottom: 1px solid #eee; font-size: 11px; color: #1a1a1a; cursor: pointer; outline: none; padding: 2px;" } 
        %>
      <% end %>
    <% elsif current_user.group.present? %>
      <%# 生徒：所属クラスをテキスト表示 %>
      <div style="display: flex; align-items: center; gap: 8px;">
        <span style="font-size: 9px; color: #ccc; letter-spacing: 0.1em;">CLASS :</span>
        <span style="font-size: 11px; color: #1a1a1a;"><%= current_user.group.name %></span>
      </div>
    <% end %>
  <% end %>
</div>

      <div style="display: flex; align-items: center; gap: 30px;">
        <% if logged_in? %>
          <div style="display: flex; align-items: center; gap: 20px;">
            <% if current_user.teacher? %>
              <%= link_to "+ NEW CLASS", new_group_path, style: "font-size: 10px; color: #1a1a1a; text-decoration: none; border-bottom: 1px solid #1a1a1a; padding-bottom: 2px; letter-spacing: 0.1em;" %>
              </div>
              <%= link_to "STUDENT LIST", users_path, style: "font-size: 10px; color: #1a1a1a; text-decoration: none; border-bottom: 1px solid #1a1a1a; padding-bottom: 2px; letter-spacing: 0.1em;" %>

            <% else %>
              <%= link_to "MY PAGE", mypage_path, style: "text-decoration: none; color: #1a1a1a; font-size: 11px; border-bottom: 1px solid #1a1a1a;" %>
            <% end %>
          </div>


          <div style="display: flex; align-items: center; gap: 15px; margin-left: 20px; border-left: 1px solid #eee; padding-left: 20px;">
            <%# 名前をクリックすると自分のプロフィール詳細(show)へ %>
            <%= link_to user_path(current_user), style: "text-decoration: none; font-size: 10px; color: #1a1a1a; letter-spacing: 0.1em;" do %>
              👤 <%= current_user.name.upcase %>
            <% end %>

            <%= button_to "LOGOUT", logout_path, 
                method: :delete, 
                form: { data: { turbo: false }, style: "display: inline;" }, 
                style: "background: none; border: 1px solid #eee; color: #999; font-size: 9px; padding: 4px 8px; cursor: pointer; font-family: inherit;" %>
          </div>
        <% else %>
          <%= link_to "LOGIN", login_path, style: "text-decoration: none; color: #1a1a1a; font-size: 11px; letter-spacing: 0.1em;" %>
        <% end %>
      </div>
    </nav>

    <%# --- Flashメッセージ --- %>
    <div class="flash-message" style="max-width: 600px; margin: 20px auto; text-align: center;">
      <% flash.each do |message_type, message| %>
        <div style="font-size: 12px; color: #666; padding: 10px; border: 1px solid #eee; background: #fff; letter-spacing: 0.05em;">
          <%= message %>
        </div>
      <% end %>
    </div>

    <%= yield %>
  </body>

  <footer style="margin-top: 100px; padding: 60px 0 40px; background-color: #ffffff; border-top: 1px solid #eee; text-align: center;">
    <div style="display: flex; justify-content: center; gap: 30px; margin-bottom: 25px;">
      <%= link_to '利用規約', terms_path, style: "text-decoration: none; color: #999; font-size: 10px; letter-spacing: 0.1em;" %>
      <%= link_to 'プライバシーポリシー', privacy_path, style: "text-decoration: none; color: #999; font-size: 10px; letter-spacing: 0.1em;" %>
    </div>
    
    <div style="font-size: 9px; color: #ccc; letter-spacing: 0.2em;">
      © <%= Time.current.year %> GROWTH NOTE
    </div>
  </footer>
  
</html>
