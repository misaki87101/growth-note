<div style="max-width: 600px; margin: 60px auto; padding: 60px; background: #fff; border: 1px solid #eee; font-family: 'Helvetica Neue', Arial, sans-serif; color: #1a1a1a;">

  <%# ヘッダー部分 %>
  <div style="text-align: center; margin-bottom: 60px; border-left: 4px solid #1a1a1a; padding-left: 20px;">
    <div style="font-size: 10px; color: #999; letter-spacing: 0.2em; margin-bottom: 8px;">
      <%= @user.teacher? ? "INSTRUCTOR" : "STUDENT" %>
    </div>
    <h2 style="font-size: 28px; font-weight: 300; letter-spacing: 0.1em; margin: 0; text-transform: uppercase;">
      <%= @user.name %>
    </h2>
  </div>

  <%# プロフィール内容 %>
  <div style="display: flex; flex-direction: column; gap: 35px;">

    <%# 誕生日 %>
    <% if @user.respond_to?(:birthday) && @user.birthday.present? %>
      <div>
        <div style="font-size: 9px; color: #bbb; letter-spacing: 0.2em; margin-bottom: 8px;">BORN / 誕生日</div>
        <div style="font-size: 15px; color: #1a1a1a; letter-spacing: 0.05em;"><%= @user.birthday.strftime("%Y.%m.%d") %></div>
      </div>
    <% end %>

    <%# 好きなもの %>
    <% if @user.favorite_things.present? %>
      <div>
        <div style="font-size: 9px; color: #bbb; letter-spacing: 0.2em; margin-bottom: 8px;">FAVORITE / 好きなもの</div>
        <div style="font-size: 15px; color: #1a1a1a;"><%= @user.favorite_things %></div>
      </div>
    <% end %>

    <%# 目標 (生徒のみ) %>
    <% if @user.student? && @user.goals.present? %>
      <div>
        <div style="font-size: 9px; color: #bbb; letter-spacing: 0.2em; margin-bottom: 8px;">GOALS / 目標</div>
        <div style="font-size: 15px; color: #1a1a1a;"><%= @user.goals %></div>
      </div>
    <% end %>
    
    <%# 経歴 %>
    <% if @user.bio.present? %>
      <div>
        <div style="font-size: 9px; color: #bbb; letter-spacing: 0.2em; margin-bottom: 8px;">BIOGRAPHY / 経歴</div>
        <div style="font-size: 14px; line-height: 1.8; color: #333; max-width: 480px;"><%= @user.bio %></div>
      </div>
    <% end %>

    <%# メッセージ (講師のみ) %>
    <% if @user.teacher? && @user.message.present? %>
      <div style="margin-top: 10px; border-top: 1px solid #eee; padding-top: 30px;">
        <div style="font-size: 9px; color: #bbb; letter-spacing: 0.2em; margin-bottom: 12px;">MESSAGE / メッセージ</div>
        <div style="font-size: 16px; font-style: italic; color: #1a1a1a; line-height: 1.6;">"<%= @user.message %>"</div>
      </div>
    <% end %>

    <%# 講師用メモ (秘密のノート) %>
    <% if current_user.teacher? && @user.student? && @user.features.present? %>
      <div style="background: #f9f9f9; padding: 30px; border: 1px solid #eee; margin-top: 20px;">
        <div style="font-size: 9px; color: #1a1a1a; letter-spacing: 0.1em; margin-bottom: 12px; font-weight: bold;">
          TEACHER'S NOTES (SECRET)
        </div>
        <div style="font-size: 13px; color: #666; line-height: 1.8;">
          <%= @user.features %>
        </div>
      </div>
    <% end %>
  </div>

  <%# 編集・戻るボタン %>
  <div style="margin-top: 80px; text-align: center; border-top: 1px solid #eee; padding-top: 20px;">
    <% back_path = current_user.teacher? ? feedbacks_path : mypage_path %>
    <%= link_to "EDIT", edit_user_path(@user), style: "font-size: 10px; color: #999; text-decoration: none; letter-spacing: 0.2em; margin-right: 25px;" %>
    <%= link_to "BACK", back_path, style: "font-size: 10px; color: #999; text-decoration: none; letter-spacing: 0.2em;" %>
  </div>

</div>