<div style="max-width: 800px; margin: 60px auto; padding: 0 20px; font-family: 'Helvetica Neue', Arial, sans-serif; color: #1a1a1a;">
  
  <%# ヘッダー部分 %>
  <div style="margin-bottom: 60px; border-bottom: 1px solid #1a1a1a; padding-bottom: 15px;">
    <h2 style="font-size: 22px; font-weight: 300; letter-spacing: 0.15em; margin: 0;">MEMBERS</h2>
    <p style="font-size: 10px; color: #999; letter-spacing: 0.05em; margin-top: 5px;">メンバー一覧</p>
  </div>

  <%# リスト部分 %>
  <div style="display: flex; flex-direction: column;">
    <% @members.each do |member| %>
      <div style="display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #f0f0f0; padding: 25px 0;">
        
        <%# 左側：生徒の名前と目標の一部 %>
        <div>
          <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 5px;">
            <%# 💡 ロールバッジ（講師か生徒か） %>
            <span style="font-size: 9px; padding: 2px 6px; letter-spacing: 0.1em; <%= member.teacher? ? 'background: #1a1a1a; color: #fff;' : 'border: 1px solid #eee; color: #999;' %>">
              <%= member.teacher? ? "TEACHER" : "STUDENT" %>
            </span>
            <%= link_to member.name, user_path(member), style: "text-decoration: none; color: inherit; font-weight: 500; font-size: 16px;" %>
          </div>
          <%# 💡 お気に入り（犬が好き、など）があれば表示 %>
          <div style="font-size: 11px; color: #999; letter-spacing: 0.02em;">
             <%= member.favorite_things.to_s.truncate(40) %>
          </div>
        </div>

        <%# 右側：操作ボタン %>
        <div style="display: flex; gap: 15px; align-items: center;">
          <%# この生徒のフィードバック一覧へ飛ぶ（絞り込み） %>
          <% if member.student? %>
          <% if current_user.teacher? || member == current_user %>
          <%= link_to feedbacks_path(student_id: member.id), style: "text-decoration: none;" do %>
            <span style="font-size: 10px; color: #1a1a1a; letter-spacing: 0.1em; border-bottom: 1px solid #1a1a1a;">VIEW LOGS</span>
          <% end %>
          <%end %>
          <% end %>

          <%# プロフィール（カルテ）編集へ %>
          <% if member == current_user || current_user.teacher? %>
            <%= link_to edit_user_path(member), style: "text-decoration: none;" do %>
              <span style="font-size: 10px; color: #fff; background: #1a1a1a; padding: 8px 15px; letter-spacing: 0.1em;">EDIT</span>
            <% end %>
          <% end %>
        </div>

      </div>
    <% end %>
  </div>

<br>
  <%# 既存アカウントで別のクラスに入室するための案内 講師のみ表示%>
<% if current_user.teacher? %>
    <div style="background: #fff; border: 1px solid #1a1a1a; padding: 40px; margin-bottom: 60px; position: relative; overflow: hidden;">
  <div style="position: absolute; top: -10px; right: -10px; font-size: 40px; color: #f9f9f9; font-weight: 900; z-index: 0; pointer-events: none;">JOIN</div>

  <div style="position: relative; z-index: 1;">
    <div style="font-size: 11px; font-weight: 600; color: #1a1a1a; letter-spacing: 0.2em; margin-bottom: 8px; text-transform: uppercase;">Register for another class</div>
    <div style="font-size: 10px; color: #999; letter-spacing: 0.05em; margin-bottom: 25px;">すでにアカウントをお持ちの方は、招待コードを入力して新しいクラスに参加できます。</div>
    
    <%= link_to new_group_join_path, style: "text-decoration: none; display: inline-block;" do %>
      <div style="background: #1a1a1a; color: #fff; padding: 15px 35px; font-size: 11px; letter-spacing: 0.15em; font-weight: 300; transition: all 0.3s ease; border: 1px solid #1a1a1a;">
        JOIN ANOTHER CLASS / 別のクラスに入室
      </div>
    <% end %>
  </div>
</div>
<% end %>

  <%# 戻るボタン %>
  <div style="margin-top: 50px; text-align: center;">
    <%= link_to "BACK TO FEEDBACKS", feedbacks_path, style: "font-size: 11px; color: #ccc; text-decoration: none; letter-spacing: 0.1em; border-bottom: 1px solid #ccc;" %>
  </div>
</div>
