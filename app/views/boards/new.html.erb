<div style="max-width: 600px; margin: 60px auto; padding: 0 20px; font-family: 'Helvetica Neue', Arial, sans-serif;">
  
  <div style="text-align: center; margin-bottom: 40px;">
    <div style="font-size: 10px; color: #999; letter-spacing: 0.2em; margin-bottom: 10px; text-transform: uppercase;">COMMUNITY</div>
    <h1 style="font-size: 20px; font-weight: 300; letter-spacing: 0.1em; text-transform: uppercase;">New Board Post</h1>
  </div>

  <%= form_with(model: @board, local: true) do |f| %>
    <% if @board.errors.any? %>
      <div style="margin-bottom: 30px; padding: 15px; border: 1px solid #ff4b5c; color: #ff4b5c; font-size: 12px;">
        <% @board.errors.full_messages.each do |message| %>
          <div>・ <%= message %></div>
        <% end %>
      </div>
    <% end %>

    <div style="display: flex; flex-direction: column; gap: 30px;">
    <% if current_user.teacher? %>
    <%# 先生の場合：担当しているクラスから選ばせる %>
    <div>
      <%= f.label :group_id, "投稿するグループを選択", style: "display: block; font-size: 10px; color: #999; letter-spacing: 0.1em; margin-bottom: 10px;" %>
      <%= f.collection_select :group_id, @user_groups, :id, :name, { prompt: "クラスを選択してください" }, 
          style: "width: 100%; padding: 12px; border: 1px solid #eee; background: #fff; font-size: 14px; border-radius: 0; outline: none;" %>
    </div>
  <% else %>
    <%# 生徒の場合：所属しているクラスのIDを隠しフィールドで送る（自動設定） %>
    <% if @user_groups.any? %>
      <%= f.hidden_field :group_id, value: @user_groups.first.id %>
      <div style="font-size: 12px; color: #666; margin-bottom: 20px;">
        投稿先: <span style="font-weight: bold;"><%= @user_groups.first.name %></span>
      </div>
    <% end %>
  <% end %>
  
      <%# カテゴリー %>
      <div>
        <%= f.label :category, "カテゴリー", style: "display: block; font-size: 10px; color: #999; letter-spacing: 0.1em; margin-bottom: 10px;" %>
        <%= f.select :category, Board.categories.keys.map { |k| [I18n.t("enums.board.category.#{k}", default: k), k] }, {}, 
            style: "width: 100%; padding: 12px; border: 1px solid #eee; background: #fff; font-size: 14px; border-radius: 0; outline: none;" %>
      </div>

      <%# タイトル %>
      <div>
        <%= f.label :title, "タイトル", style: "display: block; font-size: 10px; color: #999; letter-spacing: 0.1em; margin-bottom: 10px;" %>
        <%= f.text_field :title, placeholder: "タイトルを入力..", style: "width: 100%; padding: 12px; border: 1px solid #eee; font-size: 14px; border-radius: 0; outline: none;" %>
      </div>

      <%# 内容 %>
      <div>
        <%= f.label :content, "内容", style: "display: block; font-size: 10px; color: #999; letter-spacing: 0.1em; margin-bottom: 10px;" %>
        <%= f.text_area :content, placeholder: "メッセージを入力..", style: "width: 100%; min-height: 200px; padding: 12px; border: 1px solid #eee; font-size: 14px; line-height: 1.6; border-radius: 0; outline: none;" %>
      </div>

      <%# 画像 %>
      <div>
        <%= f.label :images, "画像を挿入する", style: "display: block; font-size: 10px; color: #999; letter-spacing: 0.1em; margin-bottom: 10px;" %>
        <%= f.file_field :images, multiple: true, accept: "image/jpeg,image/png", style: "font-size: 11px;" %>
      </div>

      <div style="margin-top: 20px;">
        <%= f.submit "POST TO BOARD", style: "width: 100%; background: #1a1a1a; color: #fff; border: none; padding: 18px; font-size: 12px; letter-spacing: 0.2em; font-weight: 500; cursor: pointer;" %>
      </div>

      <div style="text-align: center;">
        <%= link_to "CANCEL", boards_path, style: "font-size: 10px; color: #999; text-decoration: none; letter-spacing: 0.1em;" %>
      </div>
    </div>
  <% end %>
</div>