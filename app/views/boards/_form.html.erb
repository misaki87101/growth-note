<%# app/views/boards/_form.html.erb %>
<div style="display: flex; flex-direction: column; gap: 30px;">
  
  <div data-controller="image-converter" 
     data-image-converter-model-name-value="board" 
     style="max-width: 600px; margin: 0 auto;">
  <%= form_with(model: @board, local: true, data: { turbo: false }) do |f| %>
    <div style="display: flex; flex-direction: column; gap: 30px;">

  <%# --- 1. グループ選択（新規作成時のみ、または先生のみ） --- %>
  <% if @board.new_record? %>
    <% if current_user.teacher? %>
      <div>
        <%= f.label :group_id, "投稿先クラス", style: "display: block; font-size: 10px; color: #999; letter-spacing: 0.1em; margin-bottom: 10px;" %>
        <%= f.collection_select :group_id, current_user.groups, :id, :name, { prompt: "クラスを選択してください" }, 
            style: "width: 100%; border: none; border-bottom: 1px solid #eee; padding: 10px 0; font-size: 14px; outline: none; background: transparent; border-radius: 0; min-height: 44px; display: block; position: relative; z-index: 5;" %>
      </div>
    <% else %>
      <% if current_user.groups.any? %>
        <%= f.hidden_field :group_id, value: current_user.groups.first.id %>
        <div style="font-size: 12px; color: #666; margin-bottom: 10px;">
          投稿先: <span style="font-weight: bold;"><%= current_user.groups.first.name %></span>
        </div>
      <% end %>
    <% end %>
  <% end %>

  <%# --- 2. カテゴリー --- %>
  <div>
    <%= f.label :category, "CATEGORY", style: "display: block; font-size: 10px; color: #999; letter-spacing: 0.1em; margin-bottom: 10px;" %>
    <%= f.select :category, Board.categories.keys.map { |k| [I18n.t("enums.board.category.#{k}", default: k), k] }, {}, 
        style: "width: 100%; border: none; border-bottom: 1px solid #eee; padding: 10px 0; font-size: 14px; outline: none; background: transparent; border-radius: 0;" %>
  </div>

  <%# --- 3. タイトル --- %>
  <div>
    <%= f.label :title, "TITLE", style: "display: block; font-size: 10px; color: #999; letter-spacing: 0.1em; margin-bottom: 10px;" %>
    <%= f.text_field :title, placeholder: "タイトルを入力してください",
        style: "width: 100%; border: none; border-bottom: 1px solid #eee; padding: 10px 0; font-size: 18px; outline: none; border-radius: 0;" %>
  </div>

  <%# --- 4. 内容 --- %>
  <div>
    <%= f.label :content, "CONTENT", style: "display: block; font-size: 10px; color: #999; letter-spacing: 0.1em; margin-bottom: 10px;" %>
    <%= f.text_area :content, rows: 10, placeholder: "内容を入力してください",
        style: "width: 100%; border: 1px solid #eee; padding: 15px; font-size: 14px; line-height: 1.8; outline: none; border-radius: 0;" %>
  </div>

  <%# --- 5. 画像管理（編集時：既存画像の表示と削除） --- %>
<% if @board.persisted? && @board.images.attached? %>
  <div style="margin-top: 10px; border: 1px solid #eee; padding: 20px;">
    <div style="font-size: 10px; color: #999; letter-spacing: 0.1em; margin-bottom: 15px;">ATTACHED PHOTOS</div>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); gap: 15px;">
      <% @board.images.each do |image| %>
        <div style="text-align: center;">
          <%= image_tag image, style: "width: 100%; height: 80px; object-fit: cover; border: 1px solid #f0f0f0;" %>
          <%= link_to 'REMOVE', purge_image_board_path(@board, image_id: image.id), 
                    data: { turbo_method: :delete, turbo_confirm: '削除しますか？' }, 
                    style: "display: block; background: #fff5f5; color: #ff4b5c; font-size: 10px; padding: 8px 0; text-decoration: none; margin-top: 8px; border: 1px solid #ffe5e5; font-weight: bold;" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

  <%# --- 6. 画像追加（新規・編集共通） --- %>
<div>
        <%= f.label :images, "ADD PHOTOS", style: "display: block; font-size: 10px; color: #999; letter-spacing: 0.1em; margin-bottom: 10px;" %>
        <%= f.file_field :images, 
            multiple: true, 
            accept: 'image/*,.heic', 
            name: nil, # 💡 Railsの標準アップロードを無効化
            data: { 
              image_converter_target: "input", 
              action: "change->image-converter#convert" 
            } %>

        <div data-image-converter-target="status" style="display:none; font-size: 11px; margin-top: 5px; color: #666;"></div>
        <div data-image-converter-target="preview" style="margin-top: 10px; display: flex; flex-wrap: wrap; gap: 10px;"></div>
      </div>

  <%# --- 7. 送信ボタン --- %>
  <div style="display: flex; flex-direction: column; gap: 15px; margin-top: 20px;">
        <%= f.submit (@board.new_record? ? "POST TO BOARD" : "UPDATE POST"), 
            style: "background: #1a1a1a; color: #fff; border: none; padding: 18px; min-height: 55px; font-size: 13px; letter-spacing: 0.2em; cursor: pointer; width: 100%;" %>
        <%= link_to "CANCEL", (@board.new_record? ? boards_path : board_path(@board)), 
            style: "text-align: center; text-decoration: none; color: #999; font-size: 11px; letter-spacing: 0.1em; padding: 10px;" %>
      </div>
    </div>
  <% end %>
</div>