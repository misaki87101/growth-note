<%# 外枠のメインコンテナ %>
<div data-controller="feedback-form" style="max-width: 650px; margin: 60px auto; padding: 50px 60px; background-color: #ffffff; border: 1px solid #e5e5e5; border-radius: 2px; font-family: 'Helvetica Neue', 'Helvetica', 'Hiragino Sans', sans-serif; color: #1a1a1a; line-height: 1.6; letter-spacing: 0.02em;">

  <%# タイトル部分 %>
  <h2 style="font-size: 20px; font-weight: 300; text-align: center; margin-bottom: 50px; letter-spacing: 0.15em; color: #1a1a1a; text-transform: uppercase;">
    <%= action_name == 'new' ? 'New Feedback' : 'Edit Feedback' %>
  </h2>
  
  <%= form_with(model: feedback) do |f| %>
    <%# エラーメッセージの表示 %>
    <% if @feedback.errors.any? %>
      <div style="color: red; font-size: 12px; margin-bottom: 20px; padding: 10px; border: 1px solid red;">
        <p><%= @feedback.errors.count %>件のエラーがあります：</p>
        <ul>
          <% @feedback.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    
    <div style="display: flex; flex-direction: column; gap: 25px;">
      <%# クラス選択（先生だけに表示） %>
      <% if current_user.teacher? %>
        <div>
          <%= f.label :group_id, "クラス *入力必須", style: "display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: #666; margin-bottom: 8px;" %>
          <%= select_tag :group_id,
              options_from_collection_for_select(@groups, :id, :name, @feedback.group_id), 
              include_blank: "クラスを選択してください",
              id: "feedback_group_id",
              data: { action: "change->feedback-form#updateStudents" },
              style: "width: 100%; padding: 12px; border: 1px solid #e5e5e5; border-radius: 0; background: #fff; font-size: 12px; -webkit-appearance: none;" %>
        </div>
      <% end %>

      <%# 生徒選択コンテナ %>
        <%= render "feedbacks/student_select", students: @students %>

      <%# レッスン日 %>
      <div>
        <%= f.label :lesson_date, "レッスン日 *入力必須", style: "display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: #666; margin-bottom: 8px;" %>
        <%= f.date_field :lesson_date, readonly: current_user.student?, style: "font-size: 12px; width: 100%; padding: 12px; border: 1px solid #e5e5e5; border-radius: 0; background: #fff;" %>
      </div>

      <%# 講習名 %>
      <div>
        <%= f.label :title, "講習名 *入力必須", style: "display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: #666; margin-bottom: 8px;" %>
        <%= f.text_field :title, readonly: current_user.student?, placeholder: "例：夏期講習 第1回", style: "width: 100%; padding: 12px; border: 1px solid #e5e5e5; font-size: 12px;" %>
      </div>

      <%# 講習時間 %>
      <div>
        <%= f.label :time, "講習時間", style: "display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: #666; margin-bottom: 8px;" %>
        <div style="display: flex; gap: 15px;">
          <%= f.number_field :hour, readonly: current_user.student?, style: "width: 70px; padding: 12px; border: 1px solid #e5e5e5;" %> <span style="font-size: 11px;">HR</span>
          <%= f.number_field :minute, readonly: current_user.student?, style: "width: 70px; padding: 12px; border: 1px solid #e5e5e5;" %> <span style="font-size: 11px;">MIN</span>
        </div>
      </div>

      <%# 理解度 %>
      <div>
        <%= f.label :rating, "本日の理解度", style: "display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: #666; margin-bottom: 8px;" %>
        <%= f.select :rating, [["★★★★★", 5], ["★★★★", 4], ["★★★", 3], ["★★", 2], ["★", 1]], { prompt: "評価を選択" }, { disabled: current_user.student?, style: "width: 100%; padding: 12px; border: 1px solid #e5e5e5; -webkit-appearance: none;" } %>
      </div>

    <%# 項目別評価（○△×） %>
    <div style="margin: 40px 0; padding: 25px 0; border-top: 1px solid #eee; border-bottom: 1px solid #eee;">
      <%= f.label :check_items, "◎ 項目別チェック", style: "display: block; font-size: 12px; text-transform: uppercase; letter-spacing: 0.1em; color: #666; margin-bottom: 8px;" %>
      <span style="font-size: 10px; color: #666; width: 100%;">定型文を挿入:</span>

      <% if current_user.teacher? %>
        <div style="margin-bottom: 10px; display: flex; gap: 10px;">
          <button type="button" class="template-btn" data-items='["オフ削り", "フィルイン削り", "オフの完成度"]' style="background: transparent; border: 1px solid #e5e5e5; color: #1a1a1a; padding: 6px 12px; border-radius: 0; font-size: 10px; letter-spacing: 0.05em; cursor: pointer;">オフ</button>
          <button type="button" class="template-btn" data-items='["整爪", "プッシュアップ", "ニッパー", "ケアの完成度"]' style="background: transparent; border: 1px solid #e5e5e5; color: #1a1a1a; padding: 6px 12px; border-radius: 0; font-size: 10px; letter-spacing: 0.05em; cursor: pointer;">ケア</button>
          <button type="button" class="template-btn" data-items='["塗布量", "ジェルの完成度"]' style="background: transparent; border: 1px solid #e5e5e5; color: #1a1a1a; padding: 6px 12px; border-radius: 0; font-size: 10px; letter-spacing: 0.05em; cursor: pointer;">ジェル</button>
        </div>
      <% end %>

      <div style="background: #f1f5f9; padding: 10px; border-radius: 0px; font-size: 12px; margin-bottom: 15px; color: #475569;">
        <%= render 'rating_legend' %>
      </div>

      <h3 style="font-size: 13px; font-weight: 300; letter-spacing: 0.1em; margin-bottom: 20px; color: #1a1a1a; display: flex; justify-content: space-between; align-items: center;">
        Add Button
        <% if current_user.teacher? %> <%# 💡 講師の時だけ表示！ %>
        <button type="button" id="add-item-button" style="background: none; border: 1px solid #1a1a1a; color: #1a1a1a; border-radius: 50%; width: 24px; height: 24px; cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center;">+</button>
        <% end %>
      </h3>
      
      <div id="check-items-container">
        <%= f.fields_for :check_items do |item_f| %>
          <div class="check-item-row" style="display: flex; gap: 10px; margin-bottom: 12px; align-items: center;">
          <%= item_f.hidden_field :id if item_f.object.persisted? %>
            <%# タイム入力欄 %>
            <%= item_f.text_field :timestamp, placeholder: "00:00", style: "width: 60px; padding: 10px; border: 1px solid #e5e5e5; font-size: 12px; text-align: center;" %>
            <%= item_f.text_field :name, readonly: current_user.student?, placeholder: "項目名 (例: あいさつ)", style: "flex: 2; padding: 12px; border: 1px solid #e5e5e5; border-radius: 0; background: #fff; font-size: 12px;"  %>
            <%= item_f.select :result, [["◎", "◎"], ["○", "○"], ["△", "△"], ["×", "×"]], { prompt: "評価" }, { disabled: current_user.student?, style: "flex: 1; padding: 12px; border: 1px solid #e5e5e5; border-radius: 0; background: #fff; font-size: 12px;" } %>
          </div>
        <% end %>
      </div>

      <template id="item-template">
        <div class="check-item-row" style="display: flex; gap: 10px; margin-bottom: 12px; align-items: center;">
          <input type="text" name="feedback[check_items_attributes][NEW_RECORD][timestamp]" placeholder="00:00" style="width: 60px; padding: 10px; border: 1px solid #e5e5e5; font-size: 12px; text-align: center;">
          <input type="text" name="feedback[check_items_attributes][NEW_RECORD][name]" placeholder="項目名 (例: あいさつ)" style="flex: 2; padding: 10px; border: 1px solid #e5e5e5; border-radius: 0px; font-size: 12px;">
          <select name="feedback[check_items_attributes][NEW_RECORD][result]" style="flex: 1; padding: 10px; border: 1px solid #e5e5e5; border-radius: 0px; font-size: 12px;">
            <option value="">評価</option>
            <option value="◎">◎</option>
            <option value="○">○</option>
            <option value="△">△</option>
            <option value="×">×</option>
          </select>
            <% if current_user.teacher? %>
            <button type="button" class="remove-item-button" style="background: none; border: none; color: #999; cursor: pointer; font-size: 18px; font-weight: 200;">×</button>
            <% end %>
        </div>
      </template>
    </div>


    <%# --- 写真投稿 もしまた作り直すならここに入れる--- %>

    <%# 🔒 講師専用メモ（生徒には絶対に見せない） %>
<% if current_user.teacher? %>
  <div style="margin-top: 30px; padding: 20px; background-color: #fff9f9; border: 1px solid #ffe5e5; border-radius: 4px;">
    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px;">
      <span style="font-size: 14px;">🔒</span>
      <%= f.label :secret, "講師間共有メモ（生徒には非表示）", style: "font-size: 11px; font-weight: bold; color: #d9534f; text-transform: uppercase; letter-spacing: 0.1em;" %>
    </div>
    <%= f.text_area :secret, placeholder: "次回の注意点や、講師間だけで共有したい内容を入力してください...", 
        style: "width: 100%; height: 120px; padding: 12px; font-size: 12px; border: 1px solid #ffcccc; background-color: #fff; line-height: 1.6;" %>
    <p style="font-size: 10px; color: #999; margin-top: 8px;">※この欄に入力した内容は、生徒側の画面には一切表示されません。</p>
  </div>
<% end %>
    
    <%# --- 全体フィードバック --- %>
    <div style="margin-top: 25px;">
      <%= f.label :content_label, "◎ 全体フィードバック", style: "display: block; font-size: 12px; text-transform: uppercase; letter-spacing: 0.1em; color: #666; margin-bottom: 8px;" %>
      
      <% if current_user.teacher? %>
        <div style="margin-bottom: 8px; display: flex; gap: 8px; flex-wrap: wrap;">
          <span style="font-size: 10px; color: #666; width: 100%;">定型文を挿入:</span>
          <button type="button" class="phrase-btn" data-text="今日もステップアップできましたね！この調子で次回も頑張りましょう✨" style="background: transparent; border: 1px solid #e5e5e5; color: #666; padding: 6px 12px; border-radius: 0; font-size: 10px; cursor: pointer;">😊 うまくできた</button>
          <button type="button" class="phrase-btn" data-text="レッスン中に伝えた内容を振り返り、反復練習しながら自分のスキルに繋げましょう！" style="background: transparent; border: 1px solid #e5e5e5; color: #666; padding: 6px 12px; border-radius: 0; font-size: 10px; cursor: pointer;">💪 復習頑張ろう</button>
          <button type="button" class="phrase-btn" data-text="次回のレッスンは『 』の予定です。余裕があればテキストに目を通しておいてくださいね！" style="background: transparent; border: 1px solid #e5e5e5; color: #666; padding: 6px 12px; border-radius: 0; font-size: 10px; cursor: pointer;">📖 次回の予告</button>
        </div>
      <% end %>

      <div style="margin-bottom: 20px;">
        <%= f.text_area :content, id: "feedback-content", readonly: current_user.student?, 
            style: "padding: 15px; font-size: 11px; margin-bottom: 20px; color: #1a1a1a; border: 1px solid #e5e5e5; line-height: 1.8; letter-spacing: 0.02em; width: 100%; #{'background: #f5f5f5;' if current_user.student?}" %>
      </div>
    </div>

    <%= f.submit f.object.new_record? ? "CREATE FEEDBACK" : "UPDATE FEEDBACK", style: "width: 100%; padding: 16px; background-color: #1a1a1a; color: #fff; border: none; border-radius: 0; font-weight: 300; font-size: 12px; letter-spacing: 0.2em; cursor: pointer; margin-top: 10px;" %>
  <% end %> <%# 💡 保存フォーム終了 %>

        <%# 現在の写真 もし作り直すならここに入れる%>

  </div>
  
<%# JavaScript はフォームの外部（コンテナの下）に配置 %>
<script>
  // 1. 'DOMContentLoaded' を 'turbo:load' に変更する
  document.addEventListener('turbo:load', () => {
    const container = document.getElementById('check-items-container');
    const addButton = document.getElementById('add-item-button');
    const template = document.getElementById('item-template');
    const contentArea = document.getElementById('feedback-content');

    // ページ内に必要な要素がない場合は何もしない（エラー防止）
    if (!container || !template) return;

    // --- 項目の追加ボタン ---
    addButton.onclick = () => {
  let content = template.innerHTML;
  // 💡 小数点を含まない「整数」のIDを生成するように修正
  const newId = new Date().getTime(); 
  content = content.replace(/NEW_RECORD/g, newId);
  container.insertAdjacentHTML('beforeend', content);
};

    // --- イベントデリゲーション（効率的でTurboに強い書き方） ---
    document.onclick = (e) => {
      // 削除ボタン
      if (e.target.classList.contains('remove-item-button')) {
        e.target.closest('.check-item-row').remove();
      }

      // 項目別評価の「定型文を挿入」ボタン
      const templateBtn = e.target.closest('.template-btn');
if (templateBtn) {
  const items = JSON.parse(templateBtn.dataset.items);
  items.forEach((itemName, index) => { // indexを追加
    let content = template.innerHTML;
    // 💡 ここも「整数」になるように修正
    const newId = new Date().getTime() + index; 
    content = content.replace(/NEW_RECORD/g, newId);
    container.insertAdjacentHTML('beforeend', content);

    const lastRow = container.lastElementChild;
    const input = lastRow.querySelector('[name*="[name]"]');
    if (input) input.value = itemName;
  });
}

      // 全体フィードバックの「定型文を挿入」ボタン
      const phraseBtn = e.target.closest('.phrase-btn');
      if (phraseBtn && contentArea) {
        const text = phraseBtn.dataset.text;
        contentArea.value = contentArea.value ? contentArea.value + "\n" + text : text;
        contentArea.focus();
      }
    };
  });
</script>
