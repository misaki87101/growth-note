<h2><%= @user.name %> 先生</h2>
<p><%= @student.name %> さんが、新しい宿題を提出しました。</p>

<div style="background-color: #f9f9f9; padding: 15px; border: 1px solid #ddd; border-radius: 5px;">
  <%# 💡 title を lesson_date や content に変更 %>
  <p><strong>レッスン日:</strong> <%= @homework.lesson_date %></p>
</div>

<p><%= link_to "宿題の内容を確認してフィードバックを送る", homework_url(@homework) %></p>