<div style="max-width: 600px; margin: 60px auto; padding: 20px; font-family: 'Helvetica Neue', Arial, sans-serif; color: #1a1a1a;">
  
  <div style="text-align: center; margin-bottom: 40px;">
    <div style="font-size: 10px; color: #999; letter-spacing: 0.2em; margin-bottom: 10px; text-transform: uppercase;">Edit Comment</div>
    <h1 style="font-size: 20px; font-weight: 300; letter-spacing: 0.1em;">コメントの編集</h1>
  </div>

  <%= form_with(model: [@homework, @comment], local: true) do |f| %>
    <div style="margin-bottom: 25px;">
      <%= f.text_area :content, style: "width: 100%; height: 120px; padding: 15px; border: 1px solid #eee; border-radius: 4px; outline: none; font-size: 14px; line-height: 1.6; color: #444;" %>
    </div>

    <div style="display: flex; flex-direction: column; gap: 15px; text-align: center;">
      <%= f.submit "UPDATE COMMENT", style: "background: #1a1a1a; color: #fff; border: none; padding: 12px; font-size: 11px; cursor: pointer; letter-spacing: 0.1em; border-radius: 2px;" %>
      
      <%= link_to "CANCEL", homework_path(@homework), style: "font-size: 11px; color: #999; text-decoration: none; letter-spacing: 0.1em;" %>
    </div>
  <% end %>

</div>