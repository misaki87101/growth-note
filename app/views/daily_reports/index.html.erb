<div style="max-width: 800px; margin: 60px auto; padding: 0 20px; font-family: 'Helvetica Neue', Arial, sans-serif; color: #1a1a1a;">
  
  <%# 1. タイトル部分（フィードバック側と統一） %>
  <div style="text-align: center; margin-bottom: 60px;">
    <h1 style="font-size: 22px; font-weight: 300; letter-spacing: 0.15em; margin-bottom: 10px; text-transform: uppercase;">My Growth Note</h1>
    <div style="font-size: 10px; color: #999; letter-spacing: 0.2em;">DAILY REPORTS</div>
  </div>

  <%# ナビゲーションメニュー app/views/shared/_nav.html.erb%>
  <%= render 'shared/nav' %>
  
  
  <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 40px; border-bottom: 1px solid #1a1a1a; padding-bottom: 15px;">
    <h2 style="font-size: 22px; font-weight: 300; letter-spacing: 0.15em; margin: 0;">REPORT</h2>
    <%= link_to "New Report", new_daily_report_path, style: "font-size: 11px; color: #1a1a1a; text-decoration: none; letter-spacing: 0.1em; border: 1px solid #1a1a1a; padding: 8px 20px;" %>
  </div>


  <%# レポート月を選択 %>
  <div style="margin-bottom: 30px; text-align: center;">
  <%= form_with url: daily_reports_path, method: :get, local: true, class: "month-filter" do |f| %>
    <%= f.month_field :month, value: @display_month.strftime("%Y-%m"), onchange: "this.form.submit();", 
        style: "padding: 10px; border: 1px solid #eee; border-radius: 4px; font-family: inherit; color: #1a1a1a;" %>
  <% end %>
</div>


    <%# 1. 上部の集計エリア(月間売上目標、目標まであと○円、月間生産性) %>
<div style="display: flex; gap: 20px; margin-bottom: 40px; background: #fafafa; padding: 25px; border-radius: 8px;">
  <div style="flex: 1; text-align: center; border-right: 1px solid #eee;">
    <p style="font-size: 10px; color: #999; letter-spacing: 0.1em; margin-bottom: 5px;">月間売上目標</p>
    <p style="font-size: 20px; font-weight: bold; color: #1a1a1a;">
      <% target = @daily_reports.first&.current_tech_target || 0 %>
      <%= target > 0 ? number_to_currency(target, unit: "¥", precision: 0) : "未設定" %>
    </p>
  </div>
  <div style="flex: 1; text-align: center; border-right: 1px solid #eee;">
    <p style="font-size: 10px; color: #999; letter-spacing: 0.1em; margin-bottom: 5px;">目標達成まで</p>
    <p style="font-size: 20px; font-weight: bold; color: #e67e22;">
      <% remaining = @daily_reports.first&.remaining_tech_sales || 0 %>
      <%= remaining > 0 ? "あと #{number_to_currency(remaining, unit: "¥", precision: 0)}" : "GOAL!! ✨" %>
    </p>
  </div>
  <div style="flex: 1; text-align: center;">
    <p style="font-size: 10px; color: #999; letter-spacing: 0.1em; margin-bottom: 5px;">月平均生産性</p>
    <p style="font-size: 20px; font-weight: bold; color: #1a1a1a;">
      ¥<%= number_with_delimiter((@daily_reports.sum(&:total_sales) / @daily_reports.sum { |r| r.total_working_hours.to_f }).round(0)) rescue 0 %>/h
    </p>
  </div>
</div>

<%# 2. 目標未設定のアラート %>
<% if target == 0 %>
  <div style="background: #fff5f5; border: 1px solid #feb2b2; color: #c53030; padding: 15px; border-radius: 8px; margin-bottom: 30px; font-size: 12px; text-align: center;">
    今月の目標がまだ設定されていません。NEW REPORTから「今月目標」を入力してください
  </div>
<% end %>


<%# 3. テーブルの装飾 %>
<table style="width: 100%; border-collapse: collapse; font-size: 13px;">
  <thead>
    <tr style="border-bottom: 1px solid #eee; text-align: left;">
      <th style="padding: 15px 10px;">日付</th>
      <th style="padding: 15px 10px;">総売上</th>
      <th style="padding: 15px 10px;">客数（新/リ）</th>
      <th style="padding: 15px 10px;">達成率</th>
      <th style="padding: 15px 10px;">生産性</th>
      <th style="padding: 15px 10px; text-align: center;">操作</th> <%# 操作カラムを追加 %>
    </tr>
  </thead>

  <tbody>
    <% @daily_reports.each do |report| %>
      <% 
        # 土日の判定
        bg_color = case report.date.wday
                   when 6 then "#f0f7ff" # 土曜（薄い青）
                   when 0 then "#fff0f0" # 日曜（薄い赤）
                   else "#fff"
                   end
      %>
      <tr style="border-bottom: 1px solid #f9f9f9; background-color: <%= bg_color %>;">
        <%# 日付 %>
        <td style="padding: 15px 10px;"><%= report.date.strftime("%m/%d(%a)") %></td>
        
        <%# 総売上 %>
        <td style="padding: 15px 10px;"><%= number_to_currency(report.total_sales, unit: "¥", precision: 0) %></td>
        
        <%# 客数（新/リ） %>
        <td style="padding: 15px 10px;">
          <%= report.total_customers %>名 
          (<%= report.new_customers.to_i %>/<%= report.repeat_customers.to_i %>)
        </td>
        
        <%# 達成率の強調 %>
        <td style="padding: 15px 10px;">
          <% rate = report.tech_achievement_rate %>
          <span style="<%= 'color: #d63384; font-weight: bold;' if rate >= 100 %>">
            <%= rate %>%
            <%= " ✨" if rate >= 100 %>
          </span>
        </td>
        
        <%# 生産性 %>
        <td style="padding: 15px 10px;">
          ¥<%= number_with_delimiter(report.productivity) %>/h
        </td>

        <%# 修正・削除ボタンを追加 %>
        <td style="padding: 15px 10px; text-align: center; white-space: nowrap;">
          <%= link_to "修正", edit_daily_report_path(report), 
              style: "font-size: 11px; color: #666; text-decoration: none; margin-right: 12px; border: 1px solid #ddd; padding: 4px 8px; border-radius: 4px;" %>
          
          <%= link_to "削除", daily_report_path(report), 
              data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？\nこの操作は取り消せません。" }, 
              style: "font-size: 11px; color: #dc3545; text-decoration: none; border: 1px solid #ffcccc; padding: 4px 8px; border-radius: 4px; background: #fff5f5;" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%# 分析ページ（analysis）へのリンクボタン %>
<div style="margin-top: 40px; padding: 30px; background: #fafafa; border-radius: 12px; text-align: center;">
  <p style="font-size: 12px; color: #666; margin-bottom: 15px; letter-spacing: 0.1em;">
    MONTHLY INSIGHTS
  </p>
  <%= link_to "月間集計・分析データを確認する", analysis_daily_reports_path(month: @display_month.strftime("%Y-%m")), 
      style: "display: inline-block; background: #1a1a1a; color: #fff; padding: 15px 40px; text-decoration: none; font-size: 12px; letter-spacing: 0.1em; border-radius: 4px; transition: 0.3s;" %>
  <p style="font-size: 10px; color: #999; margin-top: 10px;">
    ※スタッフ別売上や来店動機の内訳を自動集計します
  </p>
</div>

</div>

