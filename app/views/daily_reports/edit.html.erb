<div style="max-width: 600px; margin: 0 auto; padding: 40px 20px;">
  <h2 style="text-align: center; font-size: 18px; letter-spacing: 0.2em; margin-bottom: 40px;">EDIT REPORT</h2>

  <%= form_with(model: @daily_report, local: true) do |f| %>
    <%# 日付 %>
    <div style="margin-bottom: 25px;">
      <%= f.label :date, "日付", style: "display: block; font-size: 11px; font-weight: bold; margin-bottom: 8px;" %>
      <%= f.date_field :date, value: Time.current.to_date, style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px;" %>
    </div>

    <%# 売上セクション %>
    <div style="display: flex; gap: 20px; margin-bottom: 25px;">
      <div style="flex: 1;">
        <%= f.label :tech_sales, "技術売上 (¥)", style: "display: block; font-size: 11px; font-weight: bold; margin-bottom: 8px;" %>
        <%= f.number_field :tech_sales, placeholder: "0", style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px;" %>
      </div>
      <div style="flex: 1;">
        <%= f.label :item_sales, "店販売上 (¥)", style: "display: block; font-size: 11px; font-weight: bold; margin-bottom: 8px;" %>
        <%= f.number_field :item_sales, placeholder: "0", style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px;" %>
      </div>
    </div>

<%# スタッフ別実績入力エリア %>
<div style="margin-bottom: 35px; border: 1px solid #eee; border-radius: 8px; overflow: hidden;">
  <div style="background: #f9f9f9; padding: 10px 15px; border-bottom: 1px solid #eee; font-size: 11px; font-weight: bold; letter-spacing: 0.1em; color: #666;">
    個人実績
  </div>
  
  <div style="padding: 20px;">
    <%= f.fields_for :staff_sales do |s| %>
      <div style="margin-bottom: 25px; border-bottom: 1px dashed #eee; padding-bottom: 20px;">
        <%# スタッフ名ラベル %>
        <div style="margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
          <span style="background: #1a1a1a; color: #fff; font-size: 9px; padding: 2px 6px; border-radius: 2px;">STAFF</span>
          <span style="font-size: 14px; font-weight: bold; color: #333;"><%= s.object.user.name %></span>
          <%= s.hidden_field :user_id %>
        </div>

        <%# 入力グリッド %>
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;">
          <div>
            <label style="display: block; font-size: 9px; color: #999; margin-bottom: 4px;">目標 (¥)</label>
            <%= s.number_field :tech_target, placeholder: "0", style: "width: 100%; padding: 8px; border: 1px solid #eee; border-radius: 4px; font-size: 12px;" %>
          </div>
          <div>
            <label style="display: block; font-size: 9px; color: #999; margin-bottom: 4px;">技術 (¥)</label>
            <%= s.number_field :tech_sales, placeholder: "0", style: "width: 100%; padding: 8px; border: 1px solid #eee; border-radius: 4px; font-size: 12px;" %>
          </div>
          <div>
            <label style="display: block; font-size: 9px; color: #999; margin-bottom: 4px;">店販 (¥)</label>
            <%= s.number_field :item_sales, placeholder: "0", style: "width: 100%; padding: 8px; border: 1px solid #eee; border-radius: 4px; font-size: 12px;" %>
          </div>
          <div>
            <label style="display: block; font-size: 9px; color: #999; margin-bottom: 4px;">時間 (h)</label>
            <%= s.number_field :working_hours, step: 0.5, placeholder: "0", style: "width: 100%; padding: 8px; border: 1px solid #eee; border-radius: 4px; font-size: 12px;" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

    <%# 客数セクション %>
    <div style="display: flex; gap: 20px; margin-bottom: 25px;">
      <div style="flex: 1;">
        <%= f.label :new_customers, "新規客数 (名)", style: "display: block; font-size: 11px; font-weight: bold; margin-bottom: 8px;" %>
        <%= f.number_field :new_customers, placeholder: "0", style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px;" %>
      </div>
      <div style="flex: 1;">
        <%= f.label :repeat_customers, "リピート客数 (名)", style: "display: block; font-size: 11px; font-weight: bold; margin-bottom: 8px;" %>
        <%= f.number_field :repeat_customers, placeholder: "0", style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px;" %>
      </div>
    </div>

    <%# 来店動機 %>
<div style="background: #fdfdfd; padding: 25px; border: 1px solid #eee; border-radius: 8px; margin-bottom: 25px;">
  <p style="font-size: 11px; font-weight: bold; margin-bottom: 20px; letter-spacing: 0.1em; color: #333; text-align: left;">新規客の来店動機内訳 (名)</p>
  
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px 40px;">
    <% DailyReport::REFERRAL_SOURCES.each do |source| %>
      <div style="display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #f0f0f0; padding-bottom: 8px;">
        <label style="font-size: 11px; color: #666;"><%= source %></label>
        <input type="number" 
       name="daily_report[referral_data][<%= source %>]" 
       value="<%= @daily_report.referral_data&.[](source) || 0 %>" 
       min="0" 
       style="width: 50px; padding: 5px; border: 1px solid #eee; border-radius: 4px; text-align: center; font-size: 12px; background: #fff;">
      </div>
    <% end %>
  </div>
</div>

    <%# 勤務・店舗状況 %>
    <div style="display: flex; gap: 20px; margin-bottom: 25px;">
      <div style="flex: 1;">
        <%= f.label :staff_count, "出勤スタッフ数", style: "display: block; font-size: 11px; font-weight: bold; margin-bottom: 8px;" %>
        <%= f.number_field :staff_count, placeholder: "0", style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px;" %>
      </div>
      <div style="flex: 1;">
        <%= f.label :total_working_hours, "総勤務時間 (h)", style: "display: block; font-size: 11px; font-weight: bold; margin-bottom: 8px;" %>
        <%= f.number_field :total_working_hours, step: "0.5", placeholder: "0.0", style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px;" %>
      </div>
    </div>

    <%# 目標入力（月1回でOKにするためのヒント付き） %>
    <div style="background: #f9f9f9; padding: 20px; border-radius: 8px; margin-top: 30px;">
      <p style="font-size: 11px; color: #666; margin-bottom: 15px;">※今月の目標：月初や変更時にのみ入力してください。</p>
      <div style="display: flex; gap: 20px;">
        <div style="flex: 1;">
          <%= f.label :tech_target, "今月目標(技術)", style: "display: block; font-size: 11px; font-weight: bold; margin-bottom: 8px;" %>
          <%= f.number_field :tech_target, style: "width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;" %>
        </div>
        <div style="flex: 1;">
          <%= f.label :item_target, "今月目標(店販)", style: "display: block; font-size: 11px; font-weight: bold; margin-bottom: 8px;" %>
          <%= f.number_field :item_target, style: "width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;" %>
        </div>
      </div>
    </div>

    <div style="text-align: center; margin-top: 40px;">
      <%= f.submit "SAVE REPORT", style: "background: #1a1a1a; color: #fff; padding: 15px 60px; border: none; font-size: 11px; letter-spacing: 0.2em; cursor: pointer; border-radius: 4px;" %>
    </div>
  <% end %>
</div>