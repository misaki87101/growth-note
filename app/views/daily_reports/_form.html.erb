<%# app/views/daily_reports/_form.html.erb %>
<div style="max-width: 600px; margin: 0 auto; padding: 20px;">
  <%= form_with(model: daily_report, local: true) do |f| %>
    
    <%# 1. 基本情報（日付） %>
    <div style="margin-bottom: 25px;">
      <%= f.label :date, "日付", style: "display: block; font-size: 11px; font-weight: bold; margin-bottom: 8px;" %>
      <%= f.date_field :date, style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box;" %>
    </div>

    <%# 2. 店舗全体の売上 %>
    <div style="display: flex; gap: 20px; margin-bottom: 25px;">
      <div style="flex: 1;">
        <%= f.label :tech_sales, "総技術売上 (¥)", style: "display: block; font-size: 11px; font-weight: bold; margin-bottom: 8px;" %>
        <%= f.number_field :tech_sales, placeholder: "0", style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box;" %>
      </div>
      <div style="flex: 1;">
        <%= f.label :item_sales, "総店販売上 (¥)", style: "display: block; font-size: 11px; font-weight: bold; margin-bottom: 8px;" %>
        <%= f.number_field :item_sales, placeholder: "0", style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box;" %>
      </div>
    </div>

    <%# 3. 個人実績（ここを大きく修正） %>
    <div style="margin-bottom: 35px; border: 1px solid #eee; border-radius: 8px; overflow: hidden;">
      <div style="background: #f9f9f9; padding: 10px 15px; border-bottom: 1px solid #eee; font-size: 11px; font-weight: bold; color: #666;">
        個人実績（スタッフ別）
      </div>
      
      <div style="padding: 20px;">
        <%= f.fields_for :staff_sales do |s| %>
          <div style="margin-bottom: 30px; border-bottom: 2px solid #f0f0f0; padding-bottom: 25px;">
            <div style="margin-bottom: 15px; display: flex; align-items: center; gap: 8px;">
              <span style="background: #1a1a1a; color: #fff; font-size: 9px; padding: 2px 6px; border-radius: 2px;">STAFF</span>
              <span style="font-size: 14px; font-weight: bold;"><%= s.object.user&.name || "名称未設定" %></span>
              <%= s.hidden_field :user_id %>
            </div>

            <%# 上段：売上目標 %>
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 15px;">
              <div>
                <label style="display: block; font-size: 9px; color: #999; margin-bottom: 4px;">目標 (¥)</label>
                <%= s.number_field :tech_target, style: "width: 100%; padding: 8px; border: 1px solid #eee; border-radius: 4px;" %>
              </div>
              <div>
                <label style="display: block; font-size: 9px; color: #999; margin-bottom: 4px;">技術 (¥)</label>
                <%= s.number_field :tech_sales, style: "width: 100%; padding: 8px; border: 1px solid #eee; border-radius: 4px;" %>
              </div>
              <div>
                <label style="display: block; font-size: 9px; color: #999; margin-bottom: 4px;">店販 (¥)</label>
                <%= s.number_field :item_sales, style: "width: 100%; padding: 8px; border: 1px solid #eee; border-radius: 4px;" %>
              </div>
            </div>

            <%# 下段：勤怠（ここをゆったり配置） %>
            <div class="staff-row" style="background: #fafafa; padding: 10px; border-radius: 4px; display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 10px; align-items: end;">
              <div>
                <label style="display: block; font-size: 9px; color: #999; margin-bottom: 4px;">始業</label>
                <input type="time" class="start-time" style="width:100%; padding:8px; border: 1px solid #eee; border-radius: 4px;">
              </div>
              <div>
                <label style="display: block; font-size: 9px; color: #999; margin-bottom: 4px;">終業</label>
                <input type="time" class="end-time" style="width:100%; padding:8px; border: 1px solid #eee; border-radius: 4px;">
              </div>
              <div>
                <label style="display: block; font-size: 9px; color: #999; margin-bottom: 4px;">休憩(分)</label>
                <input type="number" class="break-time" value="60" style="width:100%; padding:8px; border: 1px solid #eee; border-radius: 4px;">
              </div>
              <div>
                <label style="display: block; font-size: 9px; color: #999; margin-bottom: 4px;">勤務時間(h)</label>
<%= s.number_field :working_hours, 
    class: "working-hours-result", # ← ここが JS と一致している必要があります
    readonly: true, 
    step: "0.01", 
    style: "width:100%; padding:8px; background:#eef2f7; border: 1px solid #ddd; border-radius: 4px; font-weight: bold;" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

<%# ---  客数 --- %>
    <div style="display: flex; gap: 20px; margin-bottom: 25px;">
      <div style="flex: 1;">
        <%= f.label :new_customers, "新規客数 (名)", style: "display: block; font-size: 11px; font-weight: bold; margin-bottom: 8px;" %>
        <%= f.number_field :new_customers, placeholder: "0", style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box;" %>
      </div>
      <div style="flex: 1;">
        <%= f.label :repeat_customers, "再来客数 (名)", style: "display: block; font-size: 11px; font-weight: bold; margin-bottom: 8px;" %>
        <%= f.number_field :repeat_customers, placeholder: "0", style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box;" %>
      </div>
    </div>
    <%# 4. 来店動機（ハッシュ形式での保存用） %>
    <div style="margin-bottom: 35px; border: 1px solid #eee; border-radius: 8px; overflow: hidden;">
      <div style="background: #f9f9f9; padding: 10px 15px; border-bottom: 1px solid #eee; font-size: 11px; font-weight: bold; color: #666;">
        新規来店動機
      </div>
      <div style="padding: 20px; display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 15px;">
        <% DailyReport::REFERRAL_SOURCES.each do |source| %>
          <div>
            <label style="display: block; font-size: 10px; color: #999; margin-bottom: 4px;"><%= source %></label>
            <%= number_field_tag "daily_report[referral_data][#{source}]", 
    @daily_report.referral_data&.fetch(source, 0),
    style: "width: 100%; padding: 8px; border: 1px solid #eee; border-radius: 4px;" %>
          </div>
        <% end %>
      </div>
    </div>

    <%# 5. 店舗状況（生産性計算に必要な総労働時間） %>
    <div style="margin-bottom: 35px; border: 1px solid #eee; border-radius: 8px; overflow: hidden;">
      <div style="background: #f9f9f9; padding: 10px 15px; border-bottom: 1px solid #eee; font-size: 11px; font-weight: bold; color: #666;">
        店舗状況
      </div>
      <div style="padding: 20px; display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div>
          <label style="display: block; font-size: 11px; font-weight: bold; margin-bottom: 8px;">総実労働時間 (h)</label>
          <%= f.number_field :total_working_hours, 
    id: "daily_report_total_working_hours", # ← JS はこの ID を探しています
    step: "0.01", 
    readonly: true,
    style: "width: 100%; padding: 12px; background: #eef2f7; border: 1px solid #ddd; border-radius: 4px; font-weight: bold;" %>
          <p style="font-size: 9px; color: #999; margin-top: 5px;">※各スタッフの労働時間から自動計算されます</p>
        </div>
        <div>
          <label style="display: block; font-size: 11px; font-weight: bold; margin-bottom: 8px;">出勤スタッフ数</label>
          <%= f.number_field :staff_count, style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px;" %>
        </div>
      </div>
    </div>

    <%# --- 店舗全体の目標 --- %>
    <div style="display: flex; gap: 20px; margin-bottom: 25px;">
      <div style="flex: 1;">
        <%= f.label :tech_target, "店舗技術目標 (¥)", style: "display: block; font-size: 11px; font-weight: bold; margin-bottom: 8px;" %>
        <%= f.number_field :tech_target, placeholder: "0", style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box;" %>
      </div>
      <div style="flex: 1;">
        <%= f.label :item_target, "店舗店販売上目標 (¥)", style: "display: block; font-size: 11px; font-weight: bold; margin-bottom: 8px;" %>
        <%= f.number_field :item_target, placeholder: "0", style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box;" %>
      </div>
    </div>
    

    <div style="text-align: center; margin-top: 40px; padding-bottom: 60px;">
      <%= f.submit "SAVE REPORT", style: "background: #1a1a1a; color: #fff; padding: 15px 80px; border: none; font-size: 12px; letter-spacing: 0.2em; cursor: pointer; border-radius: 4px;" %>
    </div>
  <% end %>
</div>

<script>
(function() {
  // 二重登録を防ぐための関数
  const setupLaborCalculation = () => {
    console.log("🐣 監視を開始します");
    const form = document.querySelector('form');
    if (!form) return;

    // inputイベントに加えて、changeイベントも監視（ブラウザの時計マークからの入力を確実に拾うため）
    form.addEventListener('input', handleInputChange);
    form.addEventListener('change', handleInputChange);

    function handleInputChange(e) {
      const t = e.target;
      // 監視対象のクラスかチェック
      if (t.classList.contains('start-time') || 
          t.classList.contains('end-time') || 
          t.classList.contains('break-time')) {
        
        const row = t.closest('.staff-row');
        if (!row) return;

        const start = row.querySelector('.start-time').value;
        const end = row.querySelector('.end-time').value;
        const breakMin = parseInt(row.querySelector('.break-time').value) || 0;

        if (start && end) {
          const startTime = new Date(`2000-01-01T${start}:00`);
          const endTime = new Date(`2000-01-01T${end}:00`);
          let diffMs = endTime - startTime;
          
          // 日またぎ（24時間）対応
          if (diffMs < 0) diffMs += 24 * 60 * 60 * 1000;
          
          const totalHours = (diffMs / (1000 * 60 * 60)) - (breakMin / 60);
          const resultInput = row.querySelector('.working-hours-result');
          
          if (resultInput) {
            resultInput.value = Math.max(0, totalHours).toFixed(2);
            // 合計を更新
            calculateGrandTotal();
          }
        }
      }
    }

    function calculateGrandTotal() {
      const allResults = document.querySelectorAll('.working-hours-result');
      let grandTotal = 0;
      allResults.forEach(input => {
        grandTotal += parseFloat(input.value) || 0;
      });
      
      const totalDisplay = document.querySelector('#daily_report_total_working_hours');
      if (totalDisplay) {
        totalDisplay.value = grandTotal.toFixed(2);
      }
    }
    
    // 初期計算（ページを開いた時にすでに値があれば計算）
    calculateGrandTotal();
  };

  // Rails (Turbo) と 通常の読み込み両方に対応
  document.addEventListener('turbo:load', setupLaborCalculation);
  
  // 念のため即時実行（ページ内に直接書いている場合に有効）
  if (document.readyState !== 'loading') {
    setupLaborCalculation();
  }
})();
</script>