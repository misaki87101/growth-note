<div style="max-width: 1000px; margin: 0 auto; padding: 40px; font-family: sans-serif;">
  <h2 style="text-align: center; border-bottom: 2px solid #1a1a1a; padding-bottom: 10px;">
    <%= @display_month.strftime("%Y年 %m月") %> 分析表
  </h2>


<%# --- 売上サマリー（昨対比あり） --- %>
<div style="display: flex; gap: 20px; margin-bottom: 30px;">
  <div style="flex: 1; border: 1px solid #1a1a1a; padding: 20px; text-align: center;">
    <div style="font-size: 10px; color: #666;">今年 総売上</div>
    <div style="font-size: 20px; font-weight: bold;">¥<%= number_with_delimiter(@reports.sum(:tech_sales) + @reports.sum(:item_sales)) %></div>
  </div>
  
  <div style="flex: 1; border: 1px solid #ccc; padding: 20px; text-align: center; background: #f9f9f9;">
    <div style="font-size: 10px; color: #666;">前年 総売上</div>
    <div style="font-size: 20px; font-weight: bold; color: #999;">
      ¥<%= number_with_delimiter(@last_year_reports.sum(:tech_sales) + @last_year_reports.sum(:item_sales)) %>
    </div>
  </div>

  <div style="flex: 1; border: 2px solid #d63384; padding: 20px; text-align: center;">
    <div style="font-size: 10px; color: #d63384; font-weight: bold;">昨年対比</div>
    <div style="font-size: 20px; font-weight: bold; color: #d63384;">
      <% 
        this_year = @reports.sum(:tech_sales).to_f
        last_year = @last_year_reports.sum(:tech_sales).to_f
        growth = last_year > 0 ? (this_year / last_year * 100).round(1) : 0
      %>
      <%= growth %>%
    </div>
  </div>
</div>

<%# --- スタッフ別実績（目標と達成率を追加） --- %>
<table style="width: 100%; border-collapse: collapse;">
  <thead style="background: #eee; font-size: 12px;">
    <tr>
      <th>スタッフ名</th>
      <th>目標</th>
      <th>実績</th>
      <th>達成率</th>
      <th>生産性</th>
    </tr>
  </thead>
  <tbody>
    <% @staff_summary.each do |summary| %>
      <tr style="text-align: center; border-bottom: 1px solid #eee;">
        <td style="padding: 15px;"><%= User.find(summary.user_id).name %></td>
        <td style="color: #666;">¥<%= number_with_delimiter(summary.tech_target || 0) %></td>
        <td style="font-weight: bold;">¥<%= number_with_delimiter(summary.total_tech) %></td>
        <td style="color: #d63384; font-weight: bold;">
          <%= summary.tech_target.to_i > 0 ? (summary.total_tech.to_f / summary.tech_target * 100).round(1) : 0 %>%
        </td>
        <td>
  <%# total_hours を数値として評価 %>
  <% total_h = summary.total_hours.to_f %>
  <% if total_h > 0 %>
    ¥<%= number_with_delimiter((summary.total_tech.to_f / total_h).round(0)) %>/h
  <% else %>
    ¥0/h
  <% end %>
</td>
      </tr>
    <% end %>
  </tbody>
</table>


  <div style="display: flex; gap: 40px; margin-top: 40px;">
  
  <%# --- 来店動機セクション --- %>
  <div style="flex: 1; background: #fff; border: 1px solid #eee; padding: 25px; border-radius: 8px;">
    <h3 style="font-size: 13px; margin-bottom: 20px; border-left: 4px solid #1a1a1a; padding-left: 10px;">
      新規客の来店動機内訳
    </h3>
    <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
      <% DailyReport::REFERRAL_SOURCES.each do |source| %>
        <tr style="border-bottom: 1px solid #f9f9f9;">
          <td style="padding: 10px 0; color: #666;"><%= source %></td>
          <td style="padding: 10px 0; text-align: right; font-weight: bold;">
            <%= @referral_summary[source] || 0 %> <span style="font-size: 10px; font-weight: normal;">名</span>
          </td>
        </tr>
      <% end %>
      <tr style="background: #fafafa; font-weight: bold;">
        <td style="padding: 10px;">合計</td>
        <td style="padding: 10px; text-align: right;">
          <%= @referral_summary.values.map(&:to_i).sum %> 名
        </td>
      </tr>
    </table>
  </div>

  <%# --- 振り返りコメント欄 --- %>
<div style="flex: 1; background: #fff5f7; border: 1px solid #f8d7da; padding: 25px; border-radius: 8px;">
  <h3 style="font-size: 13px; margin-bottom: 15px; color: #d63384;">今月の振り返り・メモ</h3>
  
  <%= form_with(model: @monthly_note, local: true) do |f| %>
    <%= f.hidden_field :month %>
    <%= f.hidden_field :group_id %>
    
    <div style="font-size: 13px; line-height: 1.8; color: #333;">
      <%= f.text_area :memo, 
          placeholder: "今月の総括や、来月の目標を入力してください...",
          style: "width: 100%; min-height: 150px; background: #fff; border-radius: 4px; padding: 15px; border: 1px solid #eee; font-family: inherit;",
          class: "no-print" %>
      
      <%# 印刷時にはテキストだけを表示する %>
      <div class="only-print" style="display: none; min-height: 150px; background: #fff; padding: 15px; border: 1px solid #eee; white-space: pre-wrap; word-wrap: break-word; overflow-wrap: break-word; height: auto;">
  <%= @monthly_note.memo %>
</div>
    </div>

    <div style="text-align: right; margin-top: 10px;">
      <%= f.submit "メモを保存する", class: "no-print", style: "background: #d63384; color: #fff; border: none; padding: 5px 15px; border-radius: 4px; cursor: pointer; font-size: 12px;" %>
    </div>
  <% end %>
</div>
  
  <%# --- 印刷ボタン --- %>
  <%# --- 印刷ボタン（右下に固定） --- %>
<button onclick="window.print()" class="no-print floating-print-btn">
  <span style="font-size: 16px; margin-right: 5px;">🖨</span> PRINT / PDF
</button>

<style>
  /* 画面上での見た目（右下にひょっこり固定） */
  .floating-print-btn {
    position: fixed;
    bottom: 30px;
    right: 30px;
    background: #1a1a1a;
    color: #fff;
    border: none;
    padding: 12px 25px;
    border-radius: 50px; /* 丸みをつけて可愛く */
    font-size: 11px;
    font-weight: bold;
    letter-spacing: 0.1em;
    cursor: pointer;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    z-index: 1000;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
  }

  .floating-print-btn:hover {
    background: #444;
    transform: translateY(-3px); /* 浮き上がるアニメーション */
    box-shadow: 0 6px 20px rgba(0,0,0,0.3);
  }

  /* 印刷時の設定 */
  @media print {
    .no-print, .floating-print-btn {
      display: none !important;
    }
    
    .only-print {
      display: block !important;
      page-break-inside: avoid;
    }
    
    body {
      background: white !important;
    }
    
    div[style*="max-width: 1000px"] {
      margin: 0 !important;
      padding: 0 !important;
      width: 100% !important;
      max-width: 100% !important;
    }
  }
</style>
</div>